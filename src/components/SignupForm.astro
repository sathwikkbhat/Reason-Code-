---
---
<form
  action="https://reasoncode.us9.list-manage.com/subscribe/post?u=7759da4c29fbfb57ed513fd7a&id=31034764d8&f_id=0047e7e1f0"
  method="post"
  id="mc-embedded-subscribe-form"
  name="mc-embedded-subscribe-form"
  class="waitlist-form validate"
  target="_blank"
  novalidate
  aria-label="Waitlist signup form"
>
  <label for="mce-EMAIL" style="position:absolute;opacity:0;pointer-events:none;">Email Address</label>
  <input
    type="email"
    name="EMAIL"
    id="mce-EMAIL"
    class="waitlist-input required email"
    placeholder="Enter your email address"
    required
    autocomplete="email"
    aria-required="true"
    value=""
  />
  
  <!-- Honeypot anti-bot field — do not remove -->
  <div aria-hidden="true" style="position:absolute;left:-5000px;">
    <input type="text" name="b_7759da4c29fbfb57ed513fd7a_31034764d8" tabindex="-1" value="" />
  </div>

  <button type="submit" name="subscribe" id="mc-embedded-subscribe" class="waitlist-btn">
    Join Waitlist →
  </button>

  <!-- Mailchimp response messages -->
  <div id="mce-responses" style="display:none;">
    <div id="mce-error-response" style="display:none;"></div>
    <div id="mce-success-response" style="display:none;"></div>
  </div>
</form>

<div class="success-msg" id="successMsg" role="alert" aria-live="polite">
  🎉 You're on the list! We'll reach out when beta opens.
</div>